    "# Demonstrate dark energy is an illusion\n",
    "\n",
    "z_vals = np.linspace(0, 1.2, 100)\n\n# True expansion (no acceleration)\nm_true = -19.3 + 5 * np.log10(z_vals * 1.5 / 0.7) - 5\n\n# Observed (with local slingshot bias)\nm_observed = m_true.copy()\nm_observed[z_vals < 0.3] -= 0.12  # Local bias\n\n# Fit the (wrong) observed data\nfrom scipy.stats import linregress\nmask_low = z_vals < 0.5\nslope_low, intercept_low, _, _, _ = linregress(z_vals[mask_low], m_observed[mask_low])\n\nmask_high = z_vals > 0.5\nslope_high, intercept_high, _, _, _ = linregress(z_vals[mask_high], m_observed[mask_high])\n\nfig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))\n\n# Left: Hubble diagram (what observers see)\nax1.scatter(z_vals[mask_low], m_observed[mask_low], c='red', s=50, alpha=0.5, label='Nearby (biased)')\nax1.scatter(z_vals[mask_high], m_observed[mask_high], c='blue', s=50, alpha=0.5, label='Distant (less biased)')\nz_fit = np.array([0, 1.2])\nax1.plot(z_fit, slope_low * z_fit + intercept_low, 'r-', linewidth=2.5, label='Fit to nearby')\nax1.plot(z_fit, slope_high * z_fit + intercept_high, 'b--', linewidth=2.5, label='Fit to distant')\nax1.plot(z_fit, -19.3 + 5 * np.log10(z_fit * 1.5 / 0.7) - 5, 'k:', linewidth=2, label='Truth (no acceleration)', alpha=0.7)\nax1.set_xlabel('Redshift z', fontsize=11, weight='bold')\nax1.set_ylabel('Apparent magnitude m', fontsize=11, weight='bold')\nax1.set_title('Hubble Diagram: Slingshot Mimics Acceleration', fontsize=12, weight='bold')\nax1.legend(fontsize=9)\nax1.grid(True, alpha=0.3)\nax1.invert_yaxis()\n\n# Right: Inferred deceleration parameter\nq0_true = 0.0  # No acceleration\nq0_observed = (slope_low - slope_high) / slope_high * 0.5  # Mimics acceleration\n\nax2.bar(['True\\n(No Dark Energy)', 'Observed\\n(Appears to Accelerate)'],\n        [q0_true, q0_observed],\n        color=['blue', 'red'],\n        alpha=0.7,\n        edgecolor='black',\n        linewidth=2)\nax2.axhline(y=0, color='black', linestyle='--', alpha=0.5)\nax2.set_ylabel('Deceleration parameter q₀', fontsize=11, weight='bold')\nax2.set_title('Dark Energy is an Illusion\\n(Slingshot bias creates false acceleration)', fontsize=12, weight='bold')\nax2.set_ylim(-0.2, 0.5)\nfor i, q in enumerate([q0_true, q0_observed]):\n    ax2.text(i, q + 0.03, f'{q:+.2f}', ha='center', fontsize=11, weight='bold')\nax2.grid(True, alpha=0.3, axis='y')\n\nplt.tight_layout()\nplt.show()\n\nprint('CONCLUSION: Dark energy does not exist.')\nprint('The observed \"acceleration\" is slingshot bias in nearby SNe.')\nprint('True expansion is uniform (or decelerating).')\nprint('No cosmological constant needed.')"
