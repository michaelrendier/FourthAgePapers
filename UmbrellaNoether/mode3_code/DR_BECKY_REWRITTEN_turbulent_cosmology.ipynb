    "    'Perseus': {'distance': 70, 'mass': 3e14, 'impact_param': 6}\n",
    "}\n\n# Frequency shift for each cluster encounter\ndef freq_shift_from_cluster(M, b):\n    \"\"\"Blueshift from slingshot past cluster\"\"\"\n    G = 6.674e-11\n    c = 3e8\n    r_s = 2 * G * M / c**2\n    return (r_s / b)**2 * 100  # percent shift\n\nlocal_shift_total = 0\nfor cluster_name, params in local_clusters.items():\n    shift = freq_shift_from_cluster(params['mass'], params['impact_param'] * 1e20)\n    local_shift_total += shift\n    print(f'{cluster_name}: {shift:.2f}% blueshift')\n\nmagnitude_bias = -2.5 * np.log10(1 + local_shift_total/100)\nprint(f'\\nTotal local bias: {magnitude_bias:.3f} mag')\nprint(f'Distance error: {magnitude_bias * 5:.1f}%')\nprint(f'\\nThis explains the {magnitude_bias*5:.0f}% difference in measured H₀!')"
