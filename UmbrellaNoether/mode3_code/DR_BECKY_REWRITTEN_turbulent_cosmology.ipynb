    "# Hubble tension from slingshot bias\n",
    "\n",
    "# Simulated local structure (Virgo, Centaurus, Perseus clusters)\nlocal_clusters = {\n",
    "    'Virgo': {'distance': 20, 'mass': 1e15, 'impact_param': 2},\n",
